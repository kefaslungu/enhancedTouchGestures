<unit id="d826a2bc-9c62-4e9b-bc9b-573a2e8c39ff">
<notes>
<note appliesTo="source">line: 14</note>
<note appliesTo="source">prefix: * </note>
</notes>
<segment>
<source>Two finger tripple tap: quits NVDA!</source>
</segment>
</unit>
<unit id="762e675c-985e-4b47-af34-8a0728ee3b08">
<notes>
<note appliesTo="source">line: 15</note>
